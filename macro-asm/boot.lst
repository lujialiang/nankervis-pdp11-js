.MAIN.  MACRO V05.05   03:15  Page 1


      1                                 ; ===========================================================================
      2                                 ; PDP-11/70 Emulator Bootstrap Environment
      3                                 ; ===========================================================================
      4                                 ;
      5                                 ; This file provides the complete bootstrap environment for the emulator.
      6                                 ; It includes:
      7                                 ;   o Console I/O (input, output, interrupt-driven printing)
      8                                 ;   o Clock tickle for front-panel display activity
      9                                 ;   o Command interpreter and dispatcher
     10                                 ;   o Demonstration routines (lights, chaser, MMU relocation)
     11                                 ;   o Multi-device boot support (rk, rl, rp, ra, tm, pr)
     12                                 ;
     13                                 ;
     14                                 ; boot loader code
     15                                 ;mac/list:boot boot
     16                                 ;link/bot:120000 boot,odt11
     17                                 ;dump/noascii/start:120/out:tt: boot.sav
     18                                 ;
     19                                 ; ===========================================================================
     20
     21                                 ; ---------------------------------------------------------------------------
     22                                 ; macros
     23                                 ; ---------------------------------------------------------------------------
     24
     25                                     .macro lda lab,reg
     26                                         mov     pc,reg
     27                                         add     lab-.,reg          ; load address relative to pc (PIC)
     28                                     .endm
     29
     30                                 ; ---------------------------------------------------------------------------
     31                                 ; constants and device registers
     32                                 ; ---------------------------------------------------------------------------
     33
     34         177776                  psw     = 177776        ; Processor Status Word
     35         177772                  pir     = 177772        ; Programmable Interrupt Register
     36         177570                  consol  = 177570        ; Display Register (front-panel console)
     37
     38                                 ; console terminal
     39         177560                  ttks    = 177560        ; keyboard status
     40         177562                  ttkb    = 177562        ; keyboard buffer
     41         177564                  ttss    = 177564        ; transmitter status
     42         177566                  ttsb    = 177566        ; transmitter buffer
     43
