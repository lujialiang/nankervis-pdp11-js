    455 001612                                  lda #vcoded,r0      ;end of virtual code
    456
    457 001620  012246                  30$:    mov (r2)+,-(sp)     ;get a word of code
    458 001622  006623                          mtpi (r3)+          ;push into super space
    459 001624  020200                          cmp r2,r0           ;push all code to target space
    460 001626  103774                          blo 30$             ;until done
    461
    462 001630  012746  040200                  mov #40200,-(sp)
