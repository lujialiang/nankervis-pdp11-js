    863                                 ; ===========================================================================
    864                                 ; paper tape bootstrap (rt-11 lda format)
    865                                 ; ===========================================================================
    866                                 ;
    867                                 ;Paper tape boot routine using RT11 LDA format
    868                                 ;Input format:
    869                                 ;Frame
    870                                 ;  1    001
    871                                 ;  2    000
    872                                 ;  3    Low order byte count    (Includes all except checksum,
    873                                 ;  4    High order byte count    even the 001 000.)
    874                                 ;  5    Low order load address
    875                                 ;  6    High order load address
    876                                 ;  7..  Data bytes
    877                                 ;  XXX  Checksum    (Includes all the block - even the 001)








.MAIN.  MACRO V05.05   03:15  Page 1-17


    878                                 ;
    879                                 ;The checksum is calculated such that when all the bytes have
    880                                 ;been added up, the low byte of the sum will be zero.
    881                                 ;
    882                                 ;If the byte count is 6, the load address specified will be
    883                                 ;taken to be the start address of the program. If the address
    884                                 ;is even the program will be started, otherwise ODT will be
    885                                 ;re-entered.  If (count > 6), the data block will be loaded.
    886                                 ;
    887                                 ;This is the format used by DEC for paper tapes, and can be
    888                                 ;produced using the RT-11 LINK/LDA command.
    889
    890                                 ;Register use:
    891                                 ; R0 - input byte       R1 - checksum
    892                                 ; R2 - load address     R3 - byte count
    893                                 ; R4 - start address flag
    894                                 ; ---------------------------------------------------------------------------
    895
    896         177550                  ptrcsr = 177550 ;Address of reader device
    897
    898 003142     120     141     160  pterr:.asciz 'Paper tape checksum error'<15><12>
        003145     145     162     040
        003150     164     141     160
        003153     145     040     143
        003156     150     145     143
        003161     153     163     165
        003164     155     040     145
        003167     162     162     157
        003172     162     015     012
        003175     000
    899 003176     120     141     160  ptnost:.asciz 'Paper tape has no start address'<15><12>
        003201     145     162     040
        003204     164     141     160
        003207     145     040     150
        003212     141     163     040
        003215     156     157     040
        003220     163     164     141
        003223     162     164     040
        003226     141     144     144
        003231     162     145     163
        003234     163     015     012
        003237     000
    900                                 .even
    901
    902 003240                          bootpt:
    903 003240  005001                  10$:    clr r1              ;Initialize checksum
