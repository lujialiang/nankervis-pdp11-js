        001173     124     000
    290 001175     110     105     114          .asciz  "HELP"
        001200     120     000
    291 001202     114     111     107          .asciz  "LIGHTS"
        001205     110     124     123
        001210     000
    292 001211     103     110     101          .asciz  "CHASER"
        001214     123     105     122
        001217     000
    293 001220     117     104     124          .asciz  "ODT"
        001223     000
