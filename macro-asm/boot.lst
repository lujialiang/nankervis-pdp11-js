    969                                 ; ================================================================
    970                                 ;   RA (MSCP) Bootstrap for PDP-11
    971                                 ;   Loads block 0 from an RA device using a UDA50-compatible MSCP controller.








.MAIN.  MACRO V05.05   03:15  Page 1-19


    972                                 ;
    973                                 ;   Sequence:
    974                                 ;     1. Perform UDA50 INIT handshake (4 steps)
    975                                 ;     2. Issue unit ONLINE command
    976                                 ;     3. Issue READ command for block 0 address 0
    977                                 ;     4. Transfer control to loaded block
    978                                 ;
    979                                 ; ================================================================
    980
    981         172150                  udadev = 172150         ; Controller base
    982
    983         000010                  udahdr = 8.                 ; Ring header before cmd/resp pointers
    984         000010                  udrgln = 8.                 ; Ring decriptor cmd/resp data length
    985         000014                  udcpkt = udrgln + 4         ; Command packet offset from ring base (after packet header)
    986         000060                  udcpln = 60                 ; Command packet length (bytes)
    987         000100                  udrpkt = udcpkt + udcpln + 4 ; Response packet offset (after packet header)
    988         000100                  udrpln = 100                ; Response packet length
    989         000210                  udwaln = udahdr + udrpkt + udrpln ;Work area length
    990
    991 003446                          bootra:
    992 003446  010300                          mov r3, r0          ; save unit
    993
    994 003450                          udares:                 ; restart point (after unit is saved)
    995                                     ; ------------------------------------------------------------
    996                                     ; Zero the entire work area (header + rings + cmd + resp)
    997                                     ; ------------------------------------------------------------
    998 003450  012703  003646'                 mov     #udwa, r3
    999 003454  012702  000104                  mov     #udwaln/2, r2
   1000 003460                          10$:
   1001 003460  005023                          clr     (r3)+
   1002 003462  077202                          sob     r2, 10$
   1003
   1004                                     ; ------------------------------------------------------------
   1005                                     ; r5 = data table pointer
   1006                                     ; r4 = step mask (starts at 4000, shifts left each step)
   1007                                     ; r1 = UDA50 CSR
   1008                                     ; ------------------------------------------------------------
   1009 003464  012705  003630'                 mov     #udatab, r5
