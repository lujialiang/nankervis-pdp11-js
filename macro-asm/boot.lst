    408                                 ; ===========================================================================
    409                                 ; lights and mmu relocation demonstration
    410                                 ; ===========================================================================
    411                                 ;
    412                                 ; Provides:
    413                                 ;   o Rotating pattern on front-panel display
    414                                 ;   o MMU mode setup for all four modes
    415                                 ;   o Copying virtual code into mapped memory
    416                                 ;   o Executing code in relocated address space
    417                                 ;
    418                                 ; ===========================================================================
    419
    420         177572                  mmr0    = 177572
    421         177574                  mmr1    = 177574
    422         177576                  mmr2    = 177576








.MAIN.  MACRO V05.05   03:15  Page 1-9


    423         172516                  mmr3    = 172516
    424
    425         172300                  mmrk    = 172300
    426         172200                  mmrs    = 172200
    427         177600                  mmru    = 177600
    428
    429         000004                  modes   = 4.
    430
    431 001472                          lights:
    432 001472  005037  177572                  clr @#mmr0          ;turn off mmu
    433 001476                                  lda #mmupar,r5      ;get mmu page address register table
    434 001504  012704  000004                  mov #modes,r4       ;number of table entries
    435
    436 001510  012503                  10$:    mov (r5)+,r3        ;get page address register base for mode
    437 001512  100007                          bpl 20$             ;skip dummy entry for illegal mode
    438
    439 001514  005001                          clr r1              ;set base virtual relocation address to 0
    440 001516  010302                          mov r3,r2           ;pass page register address to subroutine
    441 001520  004767  000152                  jsr pc,90$          ;initialize all map pdr & par registers for mode
    442 001524  012763  177600  000076          mov #177600,76(r3)  ;point last d page (8) to i/o space
    443 001532  077412                  20$:    sob r4,10$          ;repeat for all modes
    444
    445 001534  012737  000007  172516          mov #7,@#mmr3       ;set mmu for 18 bit addressing with split i/d
    446 001542  012737  000001  177572          mov #1,@#mmr0       ;enable memory mapping
    447
    448 001550  012700  004000                  mov #4000,r0        ;relocation address for light virtual code (upper mem somewhere)
    449 001554  010037  172244                  mov r0,@#mmrs+44    ;super mode page 2 i relocation base (becomes i virtual #40000)
    450 001560  010037  172264                  mov r0,@#mmrs+64    ;super mode page 2 d relocation base
    451 001564  042737  030000  177776          bic #030000,@#psw   ;clear previous mode in psw
    452 001572  052737  010000  177776          bis #010000,@#psw   ;set pm to super
    453 001600  012703  040200                  mov #40200,r3       ;target virtual address for code (allowing 200 for data)
