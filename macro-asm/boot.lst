   1029 003514  006304                          asl     r4              ; Next step
   1030 003516  100371                          bpl     30$             ; Continue until mask goes negative
   1031
   1032                                     ; ------------------------------------------------------------
   1033                                     ; Ring buffer setup
   1034                                     ; r3 = ring base
