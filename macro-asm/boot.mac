; ===========================================================================; PDP-11/70 Emulator Bootstrap Environment; ===========================================================================;; This file provides the complete bootstrap environment for the emulator.; It includes:;   o Console I/O (input, output, interrupt-driven printing);   o Clock tickle for front-panel display activity;   o Command interpreter and dispatcher;   o Demonstration routines (lights, chaser, MMU relocation);   o Multi-device boot support (rk, rl, rp, ra, tm, pr);;; boot loader code;mac/list:boot boot;link/bot:120000 boot,odt11;dump/noascii/start:120/out:tt: boot.sav;; ===========================================================================; ---------------------------------------------------------------------------; macros; ---------------------------------------------------------------------------    .macro lda lab,reg        mov     pc,reg        add     lab-.,reg          ; load address relative to pc (PIC)    .endm; ---------------------------------------------------------------------------; constants and device registers; ---------------------------------------------------------------------------psw     = 177776        ; Processor Status Wordpir     = 177772        ; Programmable Interrupt Registerconsol  = 177570        ; Display Register (front-panel console); console terminalttks    = 177560        ; keyboard statusttkb    = 177562        ; keyboard bufferttss    = 177564        ; transmitter statusttsb    = 177566        ; transmitter buffer; ---------------------------------------------------------------------------; startup sequence; ---------------------------------------------------------------------------start:        reset        clr     @#psw        mov     #start,@#4         ; set addressing error trap        mov     #200,@#6        lda     #start, sp        add     #20000, sp         ; stack at end of current page        lda     #banner, r0        jsr     pc, print          ; print banner        sub     #256., sp          ; reserve space for command buffer        mov     sp, buffer        jsr     pc, getcmd         ; print prompt, start clock, wait for input        clr     r010$:        wait        inc     r0        br      10$                ; idle loop; ===========================================================================; static strings; ===========================================================================banner: .asciz "Paul Nankervis - paulnank@hotmail.com"<15><12><15><12>prompt: .asciz "Boot> "hlpmsg: .ascii  "Commands are BOOT, HELP, LIGHTS, CHASER, ODT"<15><12>        .ascii  "Boot devices are RK RL RP RA TM or PR"<15><12>        .asciz  "eg. Boot> BOOT rp1"<15><12><15><12>eol:    .byte   15,12,0del:    .byte   10,40,10,0unkmsg: .asciz  "Valid commands are BOOT, HELP, LIGHTS, CHASER, ODT"<12><15>badboo: .asciz  "Valid boot devices are RK RL RP RA TM and PR eg rk2"<12><15>        .even; ===========================================================================; console output routines; ===========================================================================; ---------------------------------------------------------------------------; putchr — output a single character in r0; ---------------------------------------------------------------------------putchr:10$:        tstb    @#ttss        bpl     10$        movb    r0, @#ttsb        rts     pc; ---------------------------------------------------------------------------; print — start interrupt-driven printing of a zero-terminated string;          r0 = address of string; ---------------------------------------------------------------------------prtptr: .word   0print:10$:        bitb    #100, @#ttss        bne     10$                ; wait until transmitter IE is clear        mov     r0, prtptr        lda     #prtast, r0        mov     r0, @#64           ; vector low        mov     #200, @#66         ; vector high        mov     #100, @#ttss       ; enable transmitter interrupts        rts     pc; ---------------------------------------------------------------------------; prtast — transmitter interrupt service routine; ---------------------------------------------------------------------------prtast:        tstb    @prtptr        beq     prtDone        movb    @prtptr, @#ttsb        inc     prtptr        rttprtDone:        clrb    @#ttss             ; disable transmitter IE        rtt; ===========================================================================; console input routines; ===========================================================================buffer: .word   0       ; base of input bufferbufptr: .word   0       ; current write pointer; ---------------------------------------------------------------------------; getcmd — print prompt, start clock tickle, prepare for input; ---------------------------------------------------------------------------getcmd:        lda     #prompt, r0        jsr     pc, print        mov     buffer, bufptr; install console input ISR        lda     #inpast, r0        mov     r0, @#60        mov     #200, @#62        movb    #100, @#ttks; install clock ISR        lda     #clkast, r0        mov     r0, @#100        mov     #340, @#102        movb    #100, @#177546        rts     pc; ---------------------------------------------------------------------------; clock tickle ISR — updates display register; ---------------------------------------------------------------------------clkcnt: .word   0clkast:        dec     clkcnt        mov     clkcnt, @#consol        rtt; ---------------------------------------------------------------------------; inpast — console input ISR;          handles character input, echo, editing, and command dispatch; ---------------------------------------------------------------------------inpast:        mov     r0, -(sp)        mov     r1, -(sp)        movb    @#ttkb, r0         ; get character        cmpb    r0, #40            ; below space?        blt     10$        cmpb    r0, #177           ; DEL?        bge     20$; normal printable character        mov     bufptr, r1        sub     buffer, r1        cmp     r1, #250.        bgt     40$                ; buffer full        jsr     pc, putchr         ; echo; convert lowercase - uppercase (ASCII decimal)        cmpb    r0, #97.           ; 'a'        blt     30$        cmpb    r0, #122.          ; 'z'        bgt     30$        bicb    #40, r0            ; clear ASCII case bit30$:        mov     bufptr, r1        movb    r0, (r1)+        mov     r1, bufptr        br      40$; control characters10$:        cmpb    r0, #15            ; CR?        beq     50$        cmpb    r0, #12            ; LF?        bne     40$        br      20$; backspace / delete20$:        cmp     bufptr, buffer        blos    40$        dec     bufptr        lda     #del, r0        jsr     pc, print        br      40$; carriage return — dispatch command50$:        mov     bufptr, r0        clrb    (r0)        lda     #cmd, r0        mov     r0, @#240        mov     #40, @#242        mov     #1000, @#pir       ; invoke cmd at priority 140$:        mov     (sp)+, r1        mov     (sp)+, r0        rtt; ===========================================================================; command interpreter; ===========================================================================;; Provides:;   o Prompting and command entry;   o Uppercasing and simple line editing;   o Command lookup by name;   o Dispatch to command routines;; Commands supported:;   boot, help, lights, chaser, odt;; ===========================================================================; ---------------------------------------------------------------------------; command table; ---------------------------------------------------------------------------cmdtbl:        .word   boot-.        .word   help-.        .word   lights-.        .word   chaser-.        .word   odt-.cmdlst:        .asciz  "BOOT"        .asciz  "HELP"        .asciz  "LIGHTS"        .asciz  "CHASER"        .asciz  "ODT"        .byte   0        .even; ---------------------------------------------------------------------------; cmd — main command dispatcher; ---------------------------------------------------------------------------cmd:        clr     @#pir              ; no more pir calls        mov     r0, -(sp)        mov     r1, -(sp)        mov     r2, -(sp)        mov     r3, -(sp)        mov     r4, -(sp)        mov     r5, -(sp)        lda     #eol, r0        jsr     pc, print        mov     buffer, r5         ; r5 = pointer into input buffer; skip leading spaces10$:        movb    (r5)+, r4        beq     90$                ; empty line        cmpb    r4, #40        beq     10$; r4 = first non-space character        clr     r3                 ; command index        lda     #cmdlst, r0        ; command name table; try each command in table20$:        movb    (r0)+, r1        beq     80$                ; end of table - unknown command        cmpb    r1, r4        bne     40$                ; first letter mismatch        mov     r5, r2             ; compare remaining letters30$:        movb    (r2), r1        beq     70$                ; end of input token        inc     r2        cmpb    r1, #40        beq     70$                ; space ends token        tstb    (r0)        beq     40$                ; table entry ended early        cmpb    r1, (r0)+        beq     30$; no match - skip to next command40$:        tstb    (r0)+        bne     40$        add     #2, r3        br      20$; found matching command70$:        bitb    #100, @#ttss        bne     70$                ; wait for printing to finish        lda     #cmdtbl, r0        add     r0, r3        add     (r3), r3        jsr     pc, (r3)           ; execute command routine        br      90$; unknown command80$:        lda     #unkmsg, r0        jsr     pc, print; return to prompt90$:        jsr     pc, getcmd        mov     (sp)+, r5        mov     (sp)+, r4        mov     (sp)+, r3        mov     (sp)+, r2        mov     (sp)+, r1        mov     (sp)+, r0        rtt; ---------------------------------------------------------------------------; help — print help text; ---------------------------------------------------------------------------help:        lda     #hlpmsg, r0        jsr     pc, print        rts     pc; ---------------------------------------------------------------------------; chaser — simple rotating light pattern; ---------------------------------------------------------------------------chaser:        mov     #1, r010$:        rol     r0        mov     r0, @#consol        reset                       ; loop forever        br      10$; ===========================================================================; lights and mmu relocation demonstration; ===========================================================================;; Provides:;   o Rotating pattern on front-panel display;   o MMU mode setup for all four modes;   o Copying virtual code into mapped memory;   o Executing code in relocated address space;; ===========================================================================mmr0    = 177572mmr1    = 177574mmr2    = 177576mmr3    = 172516mmrk    = 172300mmrs    = 172200mmru    = 177600modes   = 4.lights:        clr @#mmr0          ;turn off mmu        lda #mmupar,r5      ;get mmu page address register table        mov #modes,r4       ;number of table entries10$:    mov (r5)+,r3        ;get page address register base for mode        bpl 20$             ;skip dummy entry for illegal mode        clr r1              ;set base virtual relocation address to 0        mov r3,r2           ;pass page register address to subroutine        jsr pc,90$          ;initialize all map pdr & par registers for mode        mov #177600,76(r3)  ;point last d page (8) to i/o space20$:    sob r4,10$          ;repeat for all modes        mov #7,@#mmr3       ;set mmu for 18 bit addressing with split i/d        mov #1,@#mmr0       ;enable memory mapping        mov #4000,r0        ;relocation address for light virtual code (upper mem somewhere)        mov r0,@#mmrs+44    ;super mode page 2 i relocation base (becomes i virtual #40000)        mov r0,@#mmrs+64    ;super mode page 2 d relocation base        bic #030000,@#psw   ;clear previous mode in psw        bis #010000,@#psw   ;set pm to super        mov #40200,r3       ;target virtual address for code (allowing 200 for data)        lda #vcode,r2       ;where we get virtual code        lda #vcoded,r0      ;end of virtual code30$:    mov (r2)+,-(sp)     ;get a word of code        mtpi (r3)+          ;push into super space        cmp r2,r0           ;push all code to target space        blo 30$             ;until done        mov #40200,-(sp)        mtpi sp             ;set super sp        bis #030000,@#psw        mov #40140,-(sp)        mtpi sp             ;set user sp (no further sp handling needed)        mov #40200,@#240    ;start address for super pc        mov #054040,@#242   ;super mode will use alternate registers        mov #1000,@#pir     ;call #40200 in super mode at priority 1 using pir        rts pc              ;our work here is done90$:    mov #8.,r0          ;subroutine to set up mapping pdr/par registers at r2 with r1 base address95$:    mov r1,60(r2)       ;load d par        mov r1,40(r2)       ;load i par        mov #77406,20(r2)   ;load d pdr as full length read/write page        mov #77406,(r2)+    ;load i pdr        add #200,r1         ;step base address        sob r0,95$          ;repeat        rts pc;this code is copied to the target mode virtual address #40200 (on page 2);virtual addresses #40000 to #40101 reserved for wait & jmp instructionsvcode:        clr @#pir           ;turn off pir        bic #340,@#psw      ;lower priority        mov #37,r0          ;load initial display pattern (r0 displays in console data paths)        mov #174000,r1      ;load initial address pattern (r1 displays as the virtual address                            ;                              of an instruction following a wait)10$:    mov @#psw,r3        ;get current psw        jsr pc,ps2par       ;convert r3 psw to mmu page register base in r2        mov r2,r5           ;store result        mov r1,r2           ;get address to display        sub #2,r2           ;compute address of wait instruction        mov r2,r3           ;copy address to make offset        bic #177701,r3      ;make 6 bit page offset (without low bit!)        mov #0000001,40000(r3)  ;write wait instruction        mov #0000113,40002(r3)  ;write jmp (r3) instruction        mov r2,r3           ;make relocation base for wait/jmp        bic #160077,r3      ;from 7 middle address bits        ash #-6,r3          ;move into position        mov 44(r5),r4       ;get existing i page 2 base        sub r3,r4           ;calculate new relocation base for wait/jmp        ash #-12.,r2        ;3 top bits of wait address are wait page        bic #177761,r2      ;convert to word index        mov r1,r3           ;address for jmp instruction (2 after wait)        ash #-12.,r3        ;3 top bits are jmp page number        bic #177761,r3      ;convert to word index        cmp r3,r2           ;both on same page?        beq 20$             ;yes jmp doesn't need own par        add r5,r3           ;address of jmp mmu par        mov r4,40(r3)       ;set relocation base for jmp i page20$:    add r5,r2           ;address of wait mmu par        mov r4,40(r2)       ;set relocation base for wait i page        mov r1,r2           ;get address to display        sub #2,r2           ;compute address of wait instruction        bic #1,r2           ;no odd instruction addresses please :-(        lda #32$,r3         ;put jmp return address into r3        mov #3,r4           ;repeat count30$:    jmp (r2)            ;jmp to wait32$:    sob r4,30$          ;jmp (r3) comes back here        bit #1,@#consol     ;change rotation directon on switch bit zero        bne 40$        rol r1              ;rotate light pattern anticlockwise        ror r0        adc r1        br 50$40$:    rol r0              ;rotate light pattern clockwise        ror r1        adc r050$:    cmp r0,#37          ;check if start of pattern        bne 10$             ;if not we are done        bit #2,@#consol     ;don't change CPU mode if switch bit one        bne 60$        mov @#psw,r3        ;get current psw        jsr pc,ps2par       ;convert r3 psw to mmu page register base in r2        mov 44(r2),r5       ;get current mode i page 2 relocation base        add #040000,r3      ;increment cpu mode        bpl 55$        bis #040000,r3      ;skip illegal mode 255$:    jsr pc,ps2par       ;convert new r3 psw to mmu page register base in r2        mov r5,64(r2)       ;set new mode d page 2 relocation base        mov r5,44(r2)       ;set new mode i page 2 relocation base        mov r3,@#psw        ;set new mode60$:    bit #4,@#consol     ;don't fiddle with physical addressing if switch bit two        beq 70$65$:    br  10$             ;stepping stone for code below which has a branch too far70$:    mov @#psw,r3        ;get current psw        jsr pc,ps2par       ;convert r3 psw to mmu page register base in r2        mov 44(r2),r5       ;get current mode i page 2 relocation base        ccc                 ;0 fill        ror r5              ;rotate relocation base right        bic #077,r5         ;test for as far down as we dare go        bne 85$             ;if still ok use it        bit #10,@#consol    ;don't adjust 18/22 addressing if switch bit four        bne 80$        mov #20,r3          ;mmr3 22 bit mask        xor r3,@#mmr3       ;toggle 18/22 bit addressing80$:    mov #4000,r5        ;assume an 18 bit relocation address        bit #20,@#mmr3      ;ok if in 18 bit mode        beq 85$        mov #100000,r5      ;use a bigger relocation address for 22 bit85$:    mov r5,62(r2)       ;set the relocation base for d page 1 (output target area)        lda #vcoded,r3      ;get code end address (somewhere in page 2)        sub #40000,r3       ;convert to byte count from page 2 start        asr r3              ;then word count        mov #20000,r4       ;begin at the start address of page 190$:    mov 20000(r4),(r4)+ ;copy a word from page 2 to page 1        sob r3,90$          ;repeat        mov r5,64(r2)       ;set mode d page 2 relocation base        mov r5,44(r2)       ;set mode i page 2 relocation base        br 65$              ;our work here is donemmupar: .word mmrk  ; mmu page address registers by mode (note illegal mode)        .word mmrs        .word 1        .word mmrups2par:                     ;convert psw (r3) to mmu page register base address (r2)        mov r3,r2           ;don't clobber r3!        ash #-13.,r2        ;shift psw mode to bits 2 and 1        bic #177771,r2      ;clear other junk        add pc,r2           ;get relative address of        add #mmupar-.,r2    ;page address register table entry        mov (r2),r2         ;return mmu page register base for psw in r2        rts pc              ;donevcoded:                     ;end of virtual mode code; ===========================================================================; boot dispatcher; ===========================================================================;; Parses a device name and optional unit number from the command buffer,; validates it, and dispatches to the appropriate bootstrap routine.;; Supported device prefixes:;     RK, RL, RP, RA, TM, PR;; Unit numbers are parsed as octal digits (0–7), packed into r3.;; ===========================================================================; ---------------------------------------------------------------------------; device name table (two ascii chars per entry); ---------------------------------------------------------------------------boolst:        .ascii  "RK"        .ascii  "RL"        .ascii  "RP"        .ascii  "RA"        .ascii  "TM"        .ascii  "PR"        .word   0; ---------------------------------------------------------------------------; boot routine table (offsets relative to table base); ---------------------------------------------------------------------------bootbl:        .word   bootrk-.        .word   bootrl-.        .word   bootrp-.        .word   bootra-.        .word   boottm-.        .word   bootpt-.; ---------------------------------------------------------------------------; maximum unit numbers for each device; ---------------------------------------------------------------------------boomax:        .word   5, 3, 4, 4, 3, 0; ---------------------------------------------------------------------------; boot — parse device name and unit, then dispatch; ---------------------------------------------------------------------------boot:10$:        movb    (r2)+, r4        cmpb    r4, #40         ; skip leading spaces        beq     10$        tstb    r4        beq     90$             ; no device name        movb    (r2)+, r0       ; get second character        beq     90$        swab    r0        bis     r0, r4          ; r4 = two-char device code; parse unit number (octal)        clr     r320$:        movb    (r2)+, r0        beq     40$        sub     #60, r0         ; '0' = 060 octal        cmpb    r0, #7        bhi     90$        ash     #3, r3        bisb    r0, r3        br      20$40$:        clr     r2        lda     #boolst, r0     ; find device in table50$:        mov     (r0)+, r1        beq     90$             ; not found        cmp     r1, r4        beq     60$             ; device match        add     #2, r2        br      50$60$:        lda     #boomax, r0        add     r2, r0        cmp     r3, (r0)        ; validate maximum unit        bgt     90$        reset        lda     #bootbl, r0        add     r0, r2        add     (r2), r2        jsr     pc, (r2)        ; call device bootstrap (r3 = unit)        br      100$90$:        lda     #badboo, r0     ; invalid device or unit        jsr     pc, print100$:        rts     pc; ===========================================================================; device boot routines; ===========================================================================;; Each routine loads block 0 from the specified device and transfers control; to address 0. All routines expect:;;       r3 = unit number (already validated);; ===========================================================================; ===========================================================================; rk05 bootstrap (rk11); ===========================================================================rkda    = 177412bootrk:        mov     #rkda, r0        ash     #13., r3           ; unit - da bits        mov     r3, (r0)           ; da        clr     -(r0)              ; ba        mov     #-256.*2, -(r0)    ; wc = 256 words        mov     #5, -(r0)          ; read + go10$:        tstb    (r0)        bpl     10$        clr     pc; ===========================================================================; rl01/rl02 bootstrap (rl11); ===========================================================================rlcs    = 174400bootrl:        swab    r3                 ; unit - high byte        mov     #rlcs, r0        mov     #13, 4(r0)         ; seek        bis     #4, r3             ; unit + gstat        mov     r3, (r0)10$:        tstb    (r0)        bpl     10$        clr     2(r0)              ; ba        clr     4(r0)              ; da        mov     #-512., 6(r0)      ; wc        clrb    r3        bis     #14, r3            ; unit + read        mov     r3, (r0)20$:        tstb    (r0)        bpl     20$        clr     pc; ===========================================================================; rp bootstrap (rp11 / rs03 / rs04); ===========================================================================rpcsr   = 176700bootrp:        mov     #rpcsr, r1        mov     #40, 10(r1)        ; reset        mov     r3, 10(r1)         ; unit        mov     #21, (r1)          ; pack ack        mov     #10000, 32(r1)     ; 16-bit mode        mov     #-512., 2(r1)      ; wc        clr     4(r1)              ; ba        clr     6(r1)              ; da        clr     34(r1)             ; cyl        mov     #71, (r1)          ; read10$:        tstb    (r1)        bpl     10$        clrb    (r1)        mov     r3, r0             ; bsd expects unit in r0        clr     pc; ===========================================================================; tm11 magnetic tape bootstrap (tu10/tu16); ===========================================================================mtcma   = 172526boottm:        mov     r3, r0        mov     #mtcma, r1        clr     (r1)        mov     #-1, -(r1)         ; mtbrc        mov     r0, r2        swab    r2        add     #60011, r2         ; space + go        mov     r2, -(r1)10$:        tstb    (r1)        bpl     10$        mov     r0, r2        swab    r2        add     #60003, r2         ; read + go        mov     r2, (r1)20$:        tstb    (r1)        bpl     20$        clr     pc; ===========================================================================; paper tape bootstrap (rt-11 lda format); ===========================================================================;;Paper tape boot routine using RT11 LDA format;Input format:;Frame;  1    001;  2    000;  3    Low order byte count    (Includes all except checksum,;  4    High order byte count    even the 001 000.);  5    Low order load address;  6    High order load address;  7..  Data bytes;  XXX  Checksum    (Includes all the block - even the 001);;The checksum is calculated such that when all the bytes have;been added up, the low byte of the sum will be zero.;;If the byte count is 6, the load address specified will be;taken to be the start address of the program. If the address;is even the program will be started, otherwise ODT will be;re-entered.  If (count > 6), the data block will be loaded.;;This is the format used by DEC for paper tapes, and can be;produced using the RT-11 LINK/LDA command.;Register use:; R0 - input byte       R1 - checksum; R2 - load address     R3 - byte count; R4 - start address flag; ---------------------------------------------------------------------------ptrcsr = 177550 ;Address of reader devicepterr:.asciz 'Paper tape checksum error'<15><12>ptnost:.asciz 'Paper tape has no start address'<15><12>.evenbootpt:10$:    clr r1              ;Initialize checksum        jsr pc,getch        cmpb r0,#1          ;Read until start of frame        bne 10$        jsr pc,getch        tstb r0             ;Byte after start must be zero        bne 10$        jsr pc,getwd        mov r2,r3           ;Get byte count in R3        jsr pc,getwd        ;Get load address in R2        add @#consol,r2     ;Add switches for relocation        sub #6,r3        mov r3,r4           ;Flag whether there is data        ble 40$             ;If no data then must be a start address30$:    jsr pc,getch        movb r0,(r2)+       ;Put byte into memory        sob r3,30$40$:    jsr pc,getch        tstb r1             ;Verify checksum        bne chkerr        tst r4        bgt 10$             ;If that frame contained data go get more        tst r2        beq nostrt          ;If load address null then don't start        bit #1,r2        bne nostrt          ;If load address odd then don't start        jmp (r2)            ;See what happensgetwd:                  ;Get a word from reader in R2        jsr pc,getch        mov r0,r2           ;Low order        jsr pc,getch        swab r0        bis r0,r2           ;Hi order        rts pcgetch:                  ;Get a character from reader in R0        mov #ptrcsr,r0      ;Reader device        mov #1,(r0)         ;Start reader1$:     tstb (r0)        bpl 1$              ;Wait for a character        movb 2(r0),r0       ;Get it        bic #177400,r0        add r0,r1           ;Accumulate checksum        rts pcchkerr:        lda #pterr,r0        br ptendnostrt:        lda #ptnost,r0ptend:        jsr pc,print        rts pc; ================================================================;   RA (MSCP) Bootstrap for PDP‑11;   Loads block 0 from an RA device using a UDA50-compatible MSCP controller.;;   Sequence:;     1. Perform UDA50 INIT handshake (4 steps);     2. Issue unit ONLINE command;     3. Issue READ command for block 0 address 0;     4. Transfer control to loaded block;; ================================================================udadev = 172150         ; Controller baseudahdr = 8.                 ; Ring header before cmd/resp pointersudrgln = 8.                 ; Ring decriptor cmd/resp data lengthudcpkt = udrgln + 4         ; Command packet offset from ring base (after packet header)udcpln = 60                 ; Command packet length (bytes)udrpkt = udcpkt + udcpln + 4 ; Response packet offset (after packet header)udrpln = 100                ; Response packet lengthudwaln = udahdr + udrpkt + udrpln ;Work area lengthbootra:        mov r3, r0          ; save unitudares:                 ; restart point (after unit is saved)    ; ------------------------------------------------------------    ; Zero the entire work area (header + rings + cmd + resp)    ; ------------------------------------------------------------        mov     #udwa, r3        mov     #udwaln/2, r210$:        clr     (r3)+        sob     r2, 10$    ; ------------------------------------------------------------    ; r5 = data table pointer    ; r4 = step mask (starts at 4000, shifts left each step)    ; r1 = UDA50 CSR    ; ------------------------------------------------------------        mov     #udatab, r5        mov     #4000, r4        mov     #udadev, r1        clr     (r1)+           ; Kick controller into INIT sequence; ------------------------------------------------------------; UDA50 INIT handshake; Four steps, each requiring:;   - Wait for RDY bit corresponding to current step mask;   - Write next word from table to CSR;   - Shift mask left; ------------------------------------------------------------30$:        mov     (r1), r2        bmi     udares          ; Error - restart bootstrap        bit     r4, r2        beq     30$             ; Wait for this step's RDY bit        mov     (r5)+, (r1)     ; Send step data        asl     r4              ; Next step        bpl     30$             ; Continue until mask goes negative    ; ------------------------------------------------------------    ; Ring buffer setup    ; r3 = ring base    ; ------------------------------------------------------------        mov     udatab+2, r3    ; Ring base address from table        mov     r3, r2        add     #udrpkt, r2        mov     r2, (r3)        ; Response packet pointer        mov     r3, r2        add     #udcpkt, r2        mov     r2, 4(r3)       ; Command packet pointer        mov     #udcpln, -4(r2) ; Insert cmd packet length        mov     r0, 4(r2)       ; Unit number; ------------------------------------------------------------; Issue MSCP commands from table:;   .byte opcode, modifier;   Ends when next table byte = 0; ------------------------------------------------------------50$:        movb    (r5)+, 10(r2)   ; Opcode        movb    (r5)+, 15(r2)   ; Modifier (high byte of read length)        mov     r4, 2(r3)       ; Give ownership to controller (resp)        mov     r4, 6(r3)       ; Give ownership to controller (cmd)        tst     -2(r1)          ; Wake controller70$:        tst     2(r3)           ; Wait for controller to clear the OWN bit        bmi     70$        tstb    udrpkt+12(r3)   ; Non-zero MSCP status - restart bootstrap        bne     udares          ; Error - restart        tstb    (r5)            ; More commands?        bne     50$        ; ------------------------------------------------------------        ; Success: jump to loaded block 0        ; ------------------------------------------------------------        clr     -(r1)           ; Point R1 to controller (for some OS's)        clr     pc; ------------------------------------------------------------; Data table - init data followed by command data; ------------------------------------------------------------udatab:        .word   100000          ; Step 1: no vectors, no interrupts, ring sizes both = 1        .word   udwa+10         ; Step 2: Ring base address (low)        .word   0               ; Step 3: Ring base address (high)        .word   1               ; Step 4: GO        .byte   11,0            ; ONLINE command - no parameter        .byte   41,2            ; READ command - block 0, 512 bytes (in high byte)        .word   0               ; End of tableudwa:    ; ------------------------------------------------------------    ; Ring layout (relative to controller ring base at udwa + 8)    ;    ;   -8    Header: adapter purge + command/response transitions (8 bytes)    ;   +0    1 Response descriptor (4 bytes) (controller ring base)    ;   +4    1 Command descriptor (4 bytes)    ;   +8    Command packet (4 byte header + 60 bytes)    ;   +56   Response packet (4 byte header + 100 bytes)    ; ------------------------------------------------------------end:    .end    start