Odt11s  MACRO V05.05   00:19  Page 1


      1                                         .title  odt11s
      2                                         .enabl  lc, ama
      3                                         .sbttl  Initialisation & command processors.
      4
      5                                 ;Borrowed from: http://dph.fluff.org/pdp11/odts.mac
      6
      7                                 ;Version of ODT to be blown into a 2716 PROM for use as console ODT on a T-11
      8                                 ;system. This code started life as the DECUS offering ODT11X. It now has many
      9                                 ;more features resembling those of RT-11's ODT.
     10
     11                                 ;Possible additions:
     12                                 ;       XON - XOFF recognition
     13                                 ;       Aborting printout after ;W & ;E
     14                                 ;       <address>;<count>A      Ascii string print/change
     15
     16                                 ;Conditionals are:
     17                                 ;test=1         ;Define when testing the code under RT-11
     18         000001                  eis=1           ;Use the EIS instructions (Only uses SOB)
     19                                 ;lsi=1          ;Use MTPS/MFPS, not bus addr 177776 for the status register.
     20
     21                                 .if ndf,eis
     22                                         .macro  sob     r,b     ;No EIS instructions - macro to allow SOB
     23                                                 dec     r
     24                                                 bne     b
     25                                         .endm
     26                                 .endc
     27                                 .if ndf,lsi
     28         177776                          st=177776               ;Not LSI - address of status register
     29                                         .macro  mtps    status  ;Not LSI - macro to allow MTPS
     30                                                 movb    status,@#st
     31                                         .endm
     32                                 .endc
     33
     34                                 ;.if df,test
     35         000003                  o.break =       3       ;BREAK instruction - 3 for normal PDP-11s
     36 000000                                  .csect  odt11s
     37                                 ;.iff
     38                                 ;o.break        =       0       ;BREAK instruction - is 0 for T-11
     39                                 ;       .asect
     40                                 ;       .=170000
     41                                 ;.endc
     42
     43         000016                  bkp     =       16      ;Number of breakpoints-1 mult. by 2
     44         000014                  tvec    =       14      ;BREAK vector location
     45         000340                  stm     =       340     ;Priority mask - status register
     46         000020                  tbt     =       20      ;T-bit mask - status register
     47
     48         177560                  rcsr    =       177560  ;r c/sr         Console input port addresses
     49         177562                  rdb     =       177562  ;r data buffer
     50         177564                  tcsr    =       177564  ;t c/sr         Console output port addresses
     51         177566                  tdb     =       177566  ;t data buffer
     52
     53         000015                  cr      =       15      ;Carrage return
     54         000012                  lf      =       12      ;Line feed
     55
     56                                 ; Initialise ODT
     57








