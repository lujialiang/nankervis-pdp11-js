     58 000000                          odt::
     59                                 .if df,test
     60                                         jsr     r5,svttyp       ;Keep RT-11 terminal status, say hello
     61                                         .asciz  'ODT11'
     62                                         mov     #break,@#tvec   ;PC to break vector
     63                                         mov     #stm,@#tvec+2   ;Status word to break vector+2
     64                                 .iff
     65 000000  005037  004312'                 clr     csr1            ;Clear 'saved' terminal status regs.
     66                                 .endc
     67 000004  012706  004166'                 mov     #reloc,sp       ;Set up stack pointers to init. tables
     68 000010  010600                          mov     sp,r0
     69 000012  005001                          clr     r1              ;& setup some other vectors
     70 000014  005046                  1$:     clr     -(sp)           ;Clear out registers
     71 000016  012720  177777                  mov     #-1,(r0)+       ;Remove relocation constants
     72                                 .if ndf,test
     73 000022  012721  002304'                 mov     #break,(r1)+    ;Set up a load of vectors as BPT's
     74 000026  012721  000340                  mov     #stm,(r1)+
     75                                 .endc
     76 000032  020627  004126'                 cmp     sp,#ur0         ;All registers set up yet ?
     77 000036  101366                          bhi     1$              ;Loop if not
     78 000040  012737  001000  004142'         mov     #1000,usp       ;Give the user a possible stack
     79 000046  114037  004310'                 movb    -(r0),p         ;Disallow proceed
     80 000052  005037  004306'                 clr     s.t             ;Disable single instruction & T flags
     81 000056  012737  000007  004150'         mov     #7,pri          ;Set default ODT priority
     82 000064  000137  001456'                 jmp     rall            ;Clear breakpoint tables
     83
     84                                 ; Output the top RAD50 char from r4. The RAD50 character set used is:
     85                                 ;       " ABCDEFGHIJKLMNOPQRSTUVWXYZ$./0123456789"
     86                                 ;Note that in this encoding, '$' is 33, the ASCII code for escape.
     87                                 ;There's probably a nice trick in there somewhere, if I could see it :-)
     88
     89 000070  005000                  chr50o: clr     r0              ;Extract a RAD50 char from r4
     90 000072  005200                  1$:     inc     r0              ;r0 := r4/1600.   r4 := r4%1600.
     91 000074  162704  003100                  sub     #1600.,r4       ; By repeated subtraction
     92 000100  103374                          bhis    1$
     93 000102  062704  003100                  add     #1600.,r4       ;Correct for the extra subtract
     94 000106  012746  055440                  mov     #" [,-(sp)      ;Convert single RAD50 char to ASCII
     95 000112  005300                          dec     r0              ;RAD50 0 is space, is on the stack
     96 000114  001410                          beq     3$
     97 000116  000316                  2$:     swab    (sp)            ;Not space, add '@' to convert letters
     98 000120  162700  000033                  sub     #27.,r0         ;Is it really a letter ?
     99 000124  103404                          blo     3$
    100 000126  012716  044044                  mov     #"$H,(sp)       ;No, must be $./ or digit
    101 000132  005700                          tst     r0              ;Is it $ ?
    102 000134  001370                          bne     2$              ;No, add '-'+27='H' for ./01234567
    103 000136  062600                  3$:     add     (sp)+,r0        ;Convert the character
    104 000140  004537  003010'                 jsr     r5,ftyp         ;Print it out
    105 000144  005000                          clr     r0              ;Multiply r4 by octal 50 to do the next char.
    106
    107                                 ;Routine used by RAD50 conversions, and octal numeric input.
    108                                 ;After calling MUL50:   r4 := r4 * 50 + r0,  r0 := r4 * 8 + r0,  r2 := r2 + 1
    109                                 ;After calling MULIN:   r4 := r4 * 4 + r0,   r2 := r2 + 1
    110
    111 000146  006304                  mul50:  asl     r4
    112 000150  006304                          asl     r4
    113 000152  006304                          asl     r4
    114 000154  060400                          add     r4,r0








