    834                                         .sbttl  Cassette load & dump routines.
    835
    836                                 ;Process L - load a program from tape
    837
    838                                 ;Input format:
    839
    840                                 ;Frame
    841                                 ;  1    001
    842                                 ;  2    000
    843                                 ;  3    Low order byte count    (Includes all except checksum,
    844                                 ;  4    High order byte count           even the 001 000.)
    845                                 ;  5    Low order load address
    846                                 ;  6    High order load address
    847                                 ;  7..  Data bytes
    848                                 ;  XXX  Checksum        (Includes all the block - even the 001)
    849                                 ;
    850                                 ;The checksum is calculated such that when all the bytes have
    851                                 ;been added up, the low byte of the sum will be zero.
    852                                 ;
    853                                 ;If the byte count is 6, the load address specified will be
    854                                 ;taken to be the start address of the program. If the address








Odt11s  MACRO V05.05   00:19  Page 1-15
Cassette load & dump routines.

    855                                 ;is even the program will be started, otherwise ODT will be
    856                                 ;re-entered.  If (count > 6), the data block will be loaded.
    857                                 ;
    858                                 ;This is the format used by DEC for paper tapes, and can be
    859                                 ;produced using the RT-11 LINK/LDA command.
    860
    861                                 ;Register use:
    862                                 ; R0 - contents of byte         R3 - checksum
    863                                 ; R1 - load address             R4 - Word from L.GWRD; start address
    864                                 ; R2 - byte count               R5 - read subr pointer
    865
    866 003344  004737  003052'         load:   jsr     pc,ttget        ;Wait for dummy char before starting
    867 003350  010346                          mov     r3,-(sp)        ;See if any relocation wanted
    868 003352  001404                          beq     1$              ;Branch if not
    869 003354  010516                          mov     r5,(sp)         ;Wanted - get relocation address
    870 003356  001002                          bne     1$              ;If given
    871 003360  013716  004162'                 mov     l.addr,(sp)     ;None given - place after last tape
    872 003364  012705  003450'         1$:     mov     #l.read,r5      ;Setup read routine address
    873 003370  005001                          clr     r1              ;Clear out load address
    874
    875                                 ;Look for a block start
    876
    877 003372  005003                  l.ld2:  clr     r3              ;Initialise ckecksum
    878 003374  004715                          jsr     pc,(r5)         ;Read a frame
    879 003376  077003                          sob     r0,l.ld2        ;Loop 'till byte=1 (block start)
    880 003400  004715                          jsr     pc,(r5)         ;Found '1' - skip next byte
    881
    882                                 ;Get byte count & address, relocate address, if end goto L.JMP
    883
    884 003402  004737  003474'                 jsr     pc,l.gwrd       ;Get byte count word
    885 003406  010402                          mov     r4,r2           ;Save it
    886 003410  162702  000004                  sub     #4,r2           ;Correct it after reading 001,000,count
    887 003414  004737  003474'                 jsr     pc,l.gwrd       ;Get load address
    888 003420  061604                          add     (sp),r4         ;Plus relocation factor
    889 003422  005702                          tst     r2              ;Is it an end block ?
    890 003424  001431                          beq     l.jmp           ;Branch if so
    891 003426  010401                          mov     r4,r1           ;Keep as load address
    892
    893                                 ;Read in the remainder of the data block
    894
    895 003430  004715                  l.ld3:  jsr     pc,(r5)         ;Read a frame
    896 003432  002004                          bge     l.ld4           ;Branch if more data there
    897 003434  105703                          tstb    r3              ;Look at checksum
    898 003436  001755                          beq     l.ld2           ;Good sum - find next block
    899 003440  000003                  l.bad:  o.break                 ;Checksum error
    900 003442  000753                          br      l.ld2
    901
    902 003444  110021                  l.ld4:  movb    r0,(r1)+        ;Put byte in memory
    903 003446  000770                          br      l.ld3
    904
    905                                 ;Input a frame, decrement byte count, accumulate checksum
    906
    907 003450  052737  000001  177560  l.read: bis     #1,@#rcsr       ;Set cassette & reader run
    908 003456  004737  003052'                 jsr     pc,ttget        ;Then wait for char
